# See https://git-scm.com/docs/gitignore for more about ignoring files.

# dependencies
/node_modules

# hardhat build files
/artifacts
/cache
/typechain-types

# deployments (ignore local networks only)
deployments/localhost
deployments/hardhat

# testing
/coverage
coverage.json

# production
/build
/dist

# misc
.DS_Store
Thumbs.db
desktop.ini
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# env files (never commit secrets)
/.env*
!.env.example

# typescript
*.tsbuildinfo

# IDE
.vscode
.idea

# temporary
*.tmp
*.temp